# ─── Smart Garbage Complaint System — Environment Variables ──────────────────
# Copy this file to .env and fill in your values.

# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True

# ─── Gmail SMTP Configuration ───────────────────────────────────────────────
# To enable real email notifications:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Generate an App Password for "Mail"
# 5. Paste that 16-character password below (no spaces)

# Uncomment and fill these to enable real email:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST_USER=your.email@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=Smart Garbage System <your.email@gmail.com>

# Municipal authority email to receive complaint notifications
# MUNICIPAL_EMAIL=municipal.officer@yourdomain.com
